# ============================================================
# MediBridgeX Backend — Environment Template
# Copy this file to .env and fill in the real values.
# NEVER put real secrets in this file — it IS committed to git.
# ============================================================

# ── App ───────────────────────────────────────────────────
ENVIRONMENT=development   # development | production

# ── Cryptographic Secrets ─────────────────────────────────
# Generate ENCRYPTION_KEY with:  python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate JWT_SECRET with:      python3 -c "import secrets; print(secrets.token_hex(64))"
ENCRYPTION_KEY=REPLACE_WITH_GENERATED_FERNET_KEY
JWT_SECRET=REPLACE_WITH_GENERATED_64_BYTE_HEX_SECRET

# ── Database ──────────────────────────────────────────────
# Dev:        sqlite+aiosqlite:///./medibridgex.db
# Production: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./medibridgex.db

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
